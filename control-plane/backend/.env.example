# Control-plane configuration.
# Multi-tenancy: ONE Postgres instance, one database per church (db name == slug == storage folder == subdomain label).

# Registry DB for the control plane (auto-created on first run if missing).
CONTROL_DATABASE_URL=postgres://postgres:password@localhost:5432/churchnepal_control

# Superuser connection to the maintenance DB — used to CREATE/DROP church databases.
# The user needs CREATEDB privilege.
PG_SUPER_URL=postgres://postgres:password@localhost:5432/postgres

JWT_SECRET=change_me_control_secret
PORT=3100

# Church app *.sql migrations, run into each new church DB (relative to control-plane/backend).
CHURCH_MIGRATIONS_DIR=../../backend/migrations
# Per-church storage lives under <STORAGE_ROOT>/<slug>/.
STORAGE_ROOT=../../storage

BASE_DOMAIN=churchnepal.com

# Bootstrap super-admin, seeded on first startup. CHANGE THESE.
SUPER_ADMIN_EMAIL=owner@churchnepal.com
SUPER_ADMIN_PASSWORD=changeme123
