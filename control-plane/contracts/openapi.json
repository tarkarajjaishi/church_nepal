{
  "openapi": "3.0.3",
  "info": {
    "title": "ChurchNepal Control Plane API",
    "version": "1.0.0",
    "description": "API contract between control-plane frontend and backend. Used by contract tests to catch schema drift."
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" },
                  "code": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login or 2FA challenge",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": ["token", "refresh_token", "email", "role"],
                      "properties": {
                        "token": { "type": "string" },
                        "refresh_token": { "type": "string" },
                        "email": { "type": "string" },
                        "role": { "type": "string" }
                      }
                    },
                    {
                      "type": "object",
                      "required": ["twofa_required"],
                      "properties": {
                        "twofa_required": { "type": "boolean" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "operationId": "refreshToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refresh_token"],
                "properties": {
                  "refresh_token": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New access and refresh tokens",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["token", "refresh_token", "email", "role"],
                  "properties": {
                    "token": { "type": "string" },
                    "refresh_token": { "type": "string" },
                    "email": { "type": "string" },
                    "role": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "operationId": "logout",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refresh_token"],
                "properties": {
                  "refresh_token": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logout successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["success"],
                  "properties": {
                    "success": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "operationId": "me",
        "responses": {
          "200": {
            "description": "Current authenticated user",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id", "email", "role", "twofa_enabled"],
                  "properties": {
                    "id": { "type": "string" },
                    "email": { "type": "string" },
                    "role": { "type": "string" },
                    "twofa_enabled": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/reset-authenticated": {
      "post": {
        "operationId": "resetAuthenticatedPassword",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["current_password", "new_password"],
                "properties": {
                  "current_password": { "type": "string" },
                  "new_password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["success", "message"],
                  "properties": {
                    "success": { "type": "boolean" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/2fa/enroll": {
      "post": {
        "operationId": "twofaEnroll",
        "responses": {
          "200": {
            "description": "2FA enrollment details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["secret", "otpauth_url", "qr_base64"],
                  "properties": {
                    "secret": { "type": "string" },
                    "otpauth_url": { "type": "string" },
                    "qr_base64": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/2fa/verify": {
      "post": {
        "operationId": "twofaVerify",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "2FA enabled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["success", "message"],
                  "properties": {
                    "success": { "type": "boolean" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/2fa/disable": {
      "post": {
        "operationId": "twofaDisable",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "2FA disabled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["success", "message"],
                  "properties": {
                    "success": { "type": "boolean" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/churches": {
      "get": {
        "operationId": "listChurches",
        "responses": {
          "200": {
            "description": "List of churches",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "name", "slug", "subdomain", "admin_email", "status"],
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" },
                      "slug": { "type": "string" },
                      "subdomain": { "type": "string" },
                      "admin_email": { "type": "string" },
                      "status": { "type": "string" },
                      "plan": { "type": ["string", "null"] },
                      "custom_domain": { "type": ["string", "null"] },
                      "last_active_at": { "type": ["string", "null"] },
                      "storage_bytes": { "type": ["integer", "null"] },
                      "notes": { "type": ["string", "null"] },
                      "created_at": { "type": ["string", "null"] },
                      "member_count": { "type": "integer" },
                      "giving_total": { "type": "integer" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/settings": {
      "get": {
        "operationId": "getSettings",
        "responses": {
          "200": {
            "description": "Platform settings key/value map",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": { "type": ["string", "number", "boolean", "object", "array", "null"] }
                }
              }
            }
          }
        }
      }
    },
    "/api/api-keys": {
      "get": {
        "operationId": "listApiKeys",
        "responses": {
          "200": {
            "description": "List of API keys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "name", "masked_key", "scopes"],
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" },
                      "masked_key": { "type": "string" },
                      "scopes": { "type": "array", "items": { "type": "string" } },
                      "revoked_at": { "type": ["string", "null"] },
                      "last_used_at": { "type": ["string", "null"] },
                      "created_at": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/_routes": {
      "get": {
        "operationId": "listRoutes",
        "responses": {
          "200": {
            "description": "Route catalog",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["method", "path", "auth"],
                    "properties": {
                      "method": { "type": "string" },
                      "path": { "type": "string" },
                      "auth": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
