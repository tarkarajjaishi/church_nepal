# =======================
# ENVIRONMENT CONFIGURATION
# =======================

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_AUTH_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Python Auth Server
AUTH_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
AUTH_PORT=8000
AUTH_HOST=0.0.0.0
AUTH_SMTP_HOST=smtp.gmail.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USER=your-email@gmail.com
AUTH_SMTP_PASSWORD=your-app-password
AUTH_SMTP_FROM=noreply@churchnepal.com

# Rust API Backend
DATABASE_URL=postgres://postgres:password@localhost:5432/grace_church_dev
RUST_API_PORT=3002
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Multi-Tenancy
TENANTS_CONFIG=config/tenants.json
CURRENT_TENANT=churchnepal

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_BILLING=false
ENABLE_WEBHOOKS=false
ENABLE_MFA=false
ENABLE_OAUTH=false

# External Services
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
SENTRY_DSN=
