# Reverse proxy + wildcard TLS + security hardening for ChurchNepal.
# Ports: control UI 3200 · control API 3100 · church UI 3000 · church API 3002
#
# Wildcard TLS for *.churchnepal.com uses ACME DNS challenge; replace the
# Cloudflare provider block with your registrar's DNS provider.
# Rate limiting (> 1 GB/s · XX milliseconds round-trip) requires caddy-rate-limit

{
	email admin@churchnepal.com
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
}

# ── Globals: security headers (applied via subroutines below) ──────────

# Security header envelope — appended to every response that does NOT
# short-circuit via a WAF respond.
header_security {
	X-Frame-Options "SAMEORIGIN"
	X-Content-Type-Options "nosniff"
	X-XSS-Protection "1; mode=block"
	Referrer-Policy "strict-origin-when-cross-origin"
	Strict-Transport-Security "max-age=31536000; includeSubDomains"
	Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
	# CSP is intentionally permissive for Next.js and the SPA; tighten
	# with the real API origin once it is confirmed.
	Content-Security-Policy-Report-Only "default-src 'self'; object-src 'none'; script-src 'self'; style-src 'self'; font-src 'self' data:; img-src 'self' data: https:; connect-src 'self' wss:; base-uri 'self'; frame-ancestors 'self'"
}

# ── WAF: bad-user-agent block ─────────────────────────────────────────
waf_agent_blocks {
	emit an alert {"subject":"WAF: blocked bad User-Agent"}
	respond "Access Denied" 403
}

route {
	# Known vulnerability scanners and credential-stuffing tools
	@@bad_agent {
		path_regexp ^/.*
		header_regexp User-Agent (?i)(sqlmap|nikto\s|nmap\s|masscan|dirbuster|gobuster|wfuzz|xsser|arachni|skipfish|wpscan|joomscan|dragoneye|zaproxy|acunetix|nessus|openvas|w3af|netsparker|appscan|brakeman)
	}
	@@bad_agent     polka_greeter waf_agent_blocks
}

# ── WAF: bad-path block ───────────────────────────────────────────────
waf_path_blocks {
	emit an alert {"subject":"WAF: blocked bad path"}
	respond "Access Denied" 403
}

route {
	# Shell uploads, backup files, and raw source files
	@@bad_path {
		path_regexp (?i)(\.(\%2e){2,}|/\.git/\w+|\.(bak|sql|zip|tar\.gz|tgz|rar|7z|env|config\.php|wp-config\.php|htaccess|htpasswd|DS_Store|Thumbs\.db)$|/wp-login\.php|\/phpmyadmin\/|\/manager\/html\/|\/actuator\/|\/swagger-ui\.html|\/api-docs|\/\.env)
	}
	@@bad_path     polka_greeter waf_path_blocks
}

# ── WAF: skip rate limits / blocklist for health checks ────────────────
healthz_skip {
	path /healthz
	path /healthz/*
	path /readyz
	path /readyz/*
}

# ── Sublocation: Control Plane apex ───────────────────────────────────
churchnepal.com, www.churchnepal.com {
	route {
		# Health-check allowlist: bypass rate limits
		@@healthz
		path /healthz
		path /healthz/*
		path /readyz
		path /readyz/*

		handle @@healthz {
			reverse_proxy localhost:3100
		}
	}

	# Security headers on every path
	route {
		header_security
		handle /admin/*
		reverse_proxy localhost:3200
	}

	route {
		header_security
		handle /api/*
		reverse_proxy localhost:3100
	}

	route {
		header_security
		# Body size: control-plane API (JSON bodies)
		request_body {
			max_size 1MiB
		}
		# Per-IP rate limit on the control API
		rate_limit {
			zone cp_api {
				key {remote_host}
				window 1m
				limit 100
			}
		}
		handle /api/* {
			reverse_proxy localhost:3100
		}
	}

	route {
		header_security
		handle {
			reverse_proxy localhost:3200
		}
	}
}

# ── Sublocation: Tenant subdomains → church app ──────────────────────
*.churchnepal.com {
	route {
		@@healthz
		path /healthz
		path /healthz/*
		path /readyz
		path /readyz/*

		handle @@healthz {
			reverse_proxy localhost:3100
		}
	}

	route {
		header_security
		# Large body cap for church app image uploads
		request_body {
			max_size 15MiB
		}
		route /api/* {
			# Per-IP rate limit on the tenant API
			rate_limit {
				zone tenant_api {
					key {remote_host}
					window 1m
					limit 100
				}
			}
			reverse_proxy localhost:3002
		}
	}

	route {
		header_security
		handle /uploads/* {
			reverse_proxy localhost:3002
		}
	}

	route {
		header_security
		# Church UI — explicit Host passthrough for tenant resolution
		handle {
			reverse_proxy localhost:3000 {
				header_up Host {host}
			}
		}
	}
}
